# Plantilla exclusiva para desarrollo/demo local. Copiar a .env y reemplazar los placeholders.
# .env está ignorado por Git; este archivo sí se versiona. No usar datos personales ni secretos reales.

# Generar un valor aleatorio propio de al menos 32 bytes antes de ejecutar la aplicación.
JWT_SECRET=REPLACE_WITH_A_RANDOM_SECRET_OF_AT_LEAST_32_BYTES
JWT_EXPIRATION_MS=36000000

# Credenciales sintéticas del seed dev. Se codifican con BCrypt al crear usuarios.
APP_ADMIN_USERNAME=admin_demo
APP_ADMIN_PASSWORD=REPLACE_WITH_LOCAL_ADMIN_DEMO_PASSWORD
APP_CAJERO_USERNAME=cajero_demo
APP_CAJERO_PASSWORD=REPLACE_WITH_LOCAL_CASHIER_DEMO_PASSWORD
APP_CLIENTE_USERNAME=cliente_demo
APP_CLIENTE_PASSWORD=REPLACE_WITH_LOCAL_CLIENT_DEMO_PASSWORD
