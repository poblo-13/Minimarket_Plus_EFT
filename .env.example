# Solo demo/local. Copiar a .env, que no se versiona; no usar datos reales ni secretos reales.
# JWT_SECRET: valor aleatorio propio de al menos 32 bytes.
JWT_SECRET=REPLACE_WITH_RANDOM_32_BYTE_OR_LONGER_VALUE
# JWT_EXPIRATION_MS: duración del token en milisegundos.
JWT_EXPIRATION_MS=REPLACE_WITH_TOKEN_DURATION_MILLISECONDS
# DEMO_SEED_ENABLED: habilita el seed únicamente con perfil dev.
DEMO_SEED_ENABLED=REPLACE_WITH_true_TO_ENABLE
# DEMO_ADMIN_USERNAME / DEMO_ADMIN_PASSWORD: cuenta ADMIN sintética.
DEMO_ADMIN_USERNAME=REPLACE_WITH_DEMO_ADMIN_USERNAME
DEMO_ADMIN_PASSWORD=REPLACE_WITH_DEMO_ADMIN_PASSWORD
# DEMO_CAJERO_USERNAME / DEMO_CAJERO_PASSWORD: cuenta CAJERO sintética.
DEMO_CAJERO_USERNAME=REPLACE_WITH_DEMO_CAJERO_USERNAME
DEMO_CAJERO_PASSWORD=REPLACE_WITH_DEMO_CAJERO_PASSWORD
# DEMO_CLIENTE_USERNAME / DEMO_CLIENTE_PASSWORD: cuenta CLIENTE sintética.
DEMO_CLIENTE_USERNAME=REPLACE_WITH_DEMO_CLIENTE_USERNAME
DEMO_CLIENTE_PASSWORD=REPLACE_WITH_DEMO_CLIENTE_PASSWORD
